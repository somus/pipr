{
  "name": "@pipr/e2e",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "pipr-e2e-action-fixture": "./action-fixture.ts",
    "pipr-e2e-check": "./check.ts",
    "pipr-e2e-container-check": "./container-check.ts",
    "pipr-e2e-run": "./run.ts",
    "pipr-e2e-webhook-health-fixture": "./webhook-health-fixture.ts"
  },
  "scripts": {
    "test": "bun ./scenarios-cleanup.test.ts && bun ./assertions.test.ts && bun ./prompt-evals.test.ts",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "format:check": "biome format .",
    "check": "bun run lint && bun run typecheck && bun run build:deps && bun run test",
    "build:deps": "bun run --cwd ../sdk build && bun run --cwd ../runtime build",
    "check:actions": "bun ./check.ts",
    "check:container": "bun ./container-check.ts"
  },
  "dependencies": {
    "@usepipr/runtime": "workspace:*"
  }
}
