{
  "name": "@usepipr/sdk",
  "version": "0.4.3",
  "description": "TypeScript configuration SDK for Pipr code host review automation",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./internal": {
      "types": "./dist/internal.d.mts",
      "default": "./dist/internal.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/internal.ts --dts --format esm --out-dir dist",
    "typecheck": "bunx --no-install --package @typescript/native tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint src",
    "format:check": "biome format src",
    "prepack": "bun run build",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
