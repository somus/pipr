{
  "name": "@usepipr/runtime",
  "version": "0.4.0",
  "description": "Runtime package for pipr pull request review automation",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./internal/testing": {
      "types": "./dist/internal/testing.d.mts",
      "default": "./dist/internal/testing.mjs"
    },
    "./internal/review-testing": {
      "types": "./dist/internal/review-testing.d.mts",
      "default": "./dist/internal/review-testing.mjs"
    },
    "./runtime-tools-extension": {
      "types": "./dist/pi/runtime-tools-extension.d.mts",
      "default": "./dist/pi/runtime-tools-extension.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/internal/testing.ts src/internal/review-testing.ts src/pi/runtime-tools-extension.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 60000",
    "test:config-init": "bun test --timeout 60000 src/config/tests/init.test.ts",
    "test:config-loader": "bun test --timeout 60000 src/config/tests/config.test.ts src/config/tests/sdk-module.test.ts src/config/tests/ts-loader.test.ts",
    "test:core": "bun test --timeout 60000 src/host-run/tests src/commands/tests src/diff/tests src/hosts/tests src/hosts/azure-devops/tests src/hosts/bitbucket/tests src/hosts/github/tests src/hosts/gitlab/tests src/pi/tests src/review/tests src/shared/tests src/tests",
    "lint": "biome lint src",
    "format:check": "biome format src",
    "prepack": "bun run build",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "@types/bun": "1.3.14",
    "@usepipr/sdk": "0.4.0",
    "lodash-es": "4.18.1",
    "picomatch": "4.0.5",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "@types/node": "26.1.1",
    "@types/picomatch": "4.0.3"
  }
}
