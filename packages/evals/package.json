{
  "name": "@pipr/evals",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "eval": "bun run build:deps && bun ./node_modules/.bin/evalite run --threshold=90",
    "eval:dev": "bun run build:deps && bun ./node_modules/.bin/evalite watch --threshold=90",
    "eval:export": "bun run build:deps && bun ./node_modules/.bin/evalite run --threshold=90 --outputPath=./evalite-export/results.json",
    "eval:deterministic": "bun run build:deps && bun ./src/deterministic-smoke.ts",
    "eval:deterministic:run": "bun ./src/deterministic-smoke.ts",
    "build:deps": "bun run --cwd ../sdk build && bun run --cwd ../runtime build",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit",
    "format:check": "biome format src evalite.config.ts package.json tsconfig.json"
  },
  "dependencies": {
    "@usepipr/runtime": "workspace:*"
  },
  "devDependencies": {
    "evalite": "0.19.0"
  }
}
