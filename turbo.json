{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "//#format:check:root": {
      "outputs": []
    },
    "//#format:check:docs-root": {
      "outputs": []
    },
    "//#fallow:packages:root": {
      "outputs": []
    },
    "//#fallow:docs:root": {
      "dependsOn": ["@pipr/docs#typegen"],
      "outputs": []
    },
    "//#check:release-metadata:root": {
      "outputs": []
    },
    "//#check:conventional-commit:root": {
      "outputs": []
    },
    "//#check:scripts:root": {
      "outputs": []
    },
    "//#check:runtime-test-split:root": {
      "outputs": []
    },
    "//#typecheck:root": {
      "outputs": []
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": []
    }
  }
}
