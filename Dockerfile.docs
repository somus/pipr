FROM oven/bun:1.3.14-alpine@sha256:5acc90a93e91ff07bf72aa90a7c9f0fa189765aec90b47bdbf2152d2196383c0 AS build

WORKDIR /opt/pipr

COPY package.json bun.lock turbo.json tsconfig.json tsconfig.base.json ./
# Bun validates the full workspace lockfile, so every workspace manifest must
# be present. Only docs, runtime, and SDK sources are copied into the build.
COPY apps/docs/package.json apps/docs/package.json
COPY packages/cli/package.json packages/cli/package.json
COPY packages/e2e/package.json packages/e2e/package.json
COPY packages/evals/package.json packages/evals/package.json
COPY packages/runtime/package.json packages/runtime/package.json
COPY packages/sdk/package.json packages/sdk/package.json
RUN bun install --frozen-lockfile --ignore-scripts

COPY apps/docs apps/docs
COPY packages/runtime packages/runtime
COPY packages/sdk packages/sdk
RUN bun run build:docs

FROM nginx:1.30.3-alpine@sha256:0d3b80406a13a767339fbe2f41406d6c7da727ab89cf8fae399e81f780f814d1

COPY apps/docs/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /opt/pipr/apps/docs/.output/public /usr/share/nginx/html

EXPOSE 80
