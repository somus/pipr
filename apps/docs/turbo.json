{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build:generated": {
      "dependsOn": ["^build", "typegen"],
      "outputs": [".output/**"]
    },
    "typecheck:generated": {
      "dependsOn": ["^build", "typegen"]
    },
    "test:generated": {
      "dependsOn": ["^build", "typegen"]
    },
    "typegen": {
      "outputs": [".source/**", ".tanstack/**", "src/routeTree.gen.ts"]
    }
  }
}
