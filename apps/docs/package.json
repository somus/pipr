{
  "name": "@pipr/docs",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bun run typegen && NODE_OPTIONS=--localstorage-file=.cache/node-localstorage vite dev",
    "build": "bun run typegen && NODE_OPTIONS=--localstorage-file=.cache/node-localstorage vite build",
    "start": "serve .output/public --config serve.json",
    "preview": "mkdir -p .cache && NODE_OPTIONS=--localstorage-file=.cache/node-localstorage vite preview",
    "recipes:sync": "bun scripts/sync-recipes.ts",
    "recipes:check": "bun scripts/sync-recipes.ts --check",
    "test": "bun run recipes:check && bun test scripts/tests src",
    "typegen": "mkdir -p .cache && NODE_OPTIONS=--localstorage-file=.cache/node-localstorage fumadocs-mdx && tsr generate",
    "typecheck": "bun run typegen && tsc --noEmit",
    "lint": "biome lint .",
    "format:check": "biome format .",
    "check": "bun run recipes:check && bun run lint && bun run typecheck",
    "postinstall": "bun run typegen"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/roboto-mono": "5.2.9",
    "@hugeicons/core-free-icons": "4.2.2",
    "@hugeicons/react": "1.1.9",
    "@orama/orama": "3.1.18",
    "@takumi-rs/image-response": "1.8.7",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/start-static-server-functions": "1.167.18",
    "copy-to-clipboard": "4.0.2",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-ui": "16.10.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/router-cli": "1.167.18",
    "@types/mdx": "2.0.14",
    "@types/node": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "fumadocs-twoslash": "3.2.1",
    "fumadocs-typescript": "5.2.7",
    "happy-dom": "20.10.6",
    "nitro": "3.0.260610-beta",
    "serve": "14.2.6",
    "tailwindcss": "4.3.2",
    "typescript": "catalog:"
  }
}
