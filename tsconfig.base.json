{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@usepipr/sdk": ["./packages/sdk/src/index.ts"],
      "@usepipr/sdk/internal": ["./packages/sdk/src/internal.ts"],
      "@usepipr/runtime": ["./packages/runtime/src/index.ts"],
      "@usepipr/runtime/internal/testing": ["./packages/runtime/src/internal/testing.ts"],
      "@usepipr/runtime/runtime-tools-extension": [
        "./packages/runtime/src/pi/runtime-tools-extension.ts"
      ]
    },
    "strict": true,
    "ignoreDeprecations": "6.0",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["bun", "node"]
  }
}
