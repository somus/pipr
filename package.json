{
  "name": "pipr",
  "version": "0.4.3",
  "description": "Code-owned AI review across code hosts",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "bun run build:packages",
    "build:packages": "turbo run build --filter=@usepipr/sdk --filter=@usepipr/runtime --filter=@usepipr/cli",
    "build:docs": "turbo run build:generated --filter=@pipr/docs",
    "build:all": "turbo run build",
    "typecheck": "turbo run typecheck //#typecheck:root",
    "typecheck:root": "tsc --noEmit",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "bun run format:check:packages && bun run format:check:docs",
    "format:check:root": "biome format .github .pipr deploy scripts action.yml Dockerfile Dockerfile.docs package.json tsconfig.json tsconfig.base.json turbo.json release-please-config.json .release-please-manifest.json .fallowrc.json install.sh .dockerignore --files-ignore-unknown=true",
    "format:check:docs-root": "biome format docs *.md --files-ignore-unknown=true --no-errors-on-unmatched",
    "format:check:packages": "turbo run format:check --filter='!@pipr/docs' //#format:check:root",
    "format:check:docs": "turbo run format:check --filter=@pipr/docs //#format:check:docs-root",
    "fallow": "bun run fallow:packages && bun run fallow:docs && bun run fallow:audit",
    "fallow:packages": "turbo run //#fallow:packages:root",
    "fallow:packages:root": "fallow --fail-on-issues --format compact --workspace '!@pipr/docs'",
    "fallow:docs": "turbo run //#fallow:docs:root",
    "fallow:docs:root": "fallow --fail-on-issues --format compact --workspace @pipr/docs",
    "fallow:audit": "fallow audit --format compact",
    "build:release:cli": "bun packages/cli/build-release.ts",
    "check:release-artifacts": "bun scripts/verify-release-artifacts.ts",
    "check:npm-tarballs": "bun scripts/verify-npm-tarballs.ts",
    "docker:e2e": "bun scripts/docker-e2e.ts",
    "docker:docs-e2e": "bun scripts/docs-docker-e2e.ts",
    "sync:release-lockfile": "bun scripts/sync-release-lockfile.ts",
    "hooks-install": "hk install --mise",
    "check:runtime-test-split": "turbo run //#check:runtime-test-split:root",
    "check:runtime-test-split:root": "bun scripts/check-runtime-test-split.ts",
    "check:release-metadata": "turbo run //#check:release-metadata:root",
    "check:release-metadata:root": "bun scripts/check-release-metadata.ts",
    "check:conventional-commit": "turbo run //#check:conventional-commit:root",
    "check:conventional-commit:root": "bun scripts/check-conventional-commit.ts --message \"chore: validate conventional commit check\"",
    "check:scripts": "turbo run //#check:scripts:root",
    "check:scripts:root": "bun test scripts/tests",
    "check:quality": "turbo run //#check:release-metadata:root //#check:conventional-commit:root //#check:scripts:root //#check:runtime-test-split:root //#typecheck:root //#format:check:root //#fallow:packages:root",
    "check:quality:docs": "turbo run //#format:check:docs-root //#fallow:docs:root",
    "check:packages": "bun run build:packages && turbo run lint typecheck test format:check --filter='!@pipr/docs' && bun run check:quality",
    "check:docs": "turbo run lint typecheck:generated test:generated build:generated format:check --filter=@pipr/docs && bun run check:quality:docs",
    "check": "bun run check:packages && bun run check:docs && bun run fallow:audit",
    "check:actions": "bun run --cwd packages/e2e check:actions",
    "eval:prompts": "bun run --cwd packages/evals eval"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "fallow": "3.6.0",
    "tsdown": "0.22.12",
    "turbo": "2.10.5",
    "typescript": "catalog:"
  }
}
